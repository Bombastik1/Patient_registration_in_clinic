<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TabPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="800.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sumdu.edu.ua.MainController">
    <tabs>
        <Tab fx:id="tabPatients" text="Пацієнти">
            <content>
                <AnchorPane fx:id="panePatients">
                    <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="searchField" promptText="Пошук" HBox.hgrow="ALWAYS" />
                                        <ComboBox fx:id="searchCriterionCombo" prefWidth="120.0" promptText="Критерій" />
                                        <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" prefWidth="80.0" text="Пошук" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnAddPatient" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddPatient" text="Додати пацієнта" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnUpdatePatient" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdatePatient" text="Оновити пацієнта" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnDeletePatient" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeletePatient" text="Видалити пацієнта" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <TableView fx:id="patientsTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colPatientId" maxWidth="100.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                        <TableColumn fx:id="colFullName" text="ПІБ" />
                                        <TableColumn fx:id="colGender" maxWidth="150.0" minWidth="50.0" prefWidth="70.0" text="Стать" />
                                        <TableColumn fx:id="colBirthDate" maxWidth="200.0" minWidth="100.0" prefWidth="120.0" text="Дата народження" />
                                        <TableColumn fx:id="colPatientCityName" text="Місто" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </content>
        </Tab>

        <Tab fx:id="tabVisits" text="Візити">
            <content>
                <AnchorPane fx:id="paneVisits">
                    <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnAddVisit" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddVisit" text="Записати на візит" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnDeleteVisit" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeleteVisit" text="Скасувати візит" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <TableView fx:id="visitsTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colVisitId" maxWidth="100.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                        <TableColumn fx:id="colVisitDate" maxWidth="200.0" minWidth="80.0" prefWidth="100.0" text="Дата" />
                                        <TableColumn fx:id="colPatientName" text="Пацієнт" />
                                        <TableColumn fx:id="colPatientDiagnosisName" text="Діагноз" />
                                        <TableColumn fx:id="colClinicalNotes" text="Нотатки" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </content>
        </Tab>

        <Tab fx:id="tabDictionaries" text="Довідники">
            <content>
                <AnchorPane fx:id="paneDictionaries">
                    <children>
                        <HBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="citiesTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colCityId" maxWidth="100.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colCityName" text="Назва міста" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                        <TextField fx:id="cityNameField" promptText="Впишіть нове місто" />
                                        <Button fx:id="btnAddCity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddCity" text="Додати місто" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="diagnosesTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colDiagnosisId" maxWidth="100.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colDiagnosisName" text="Назва діагнозу" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                        <TextField fx:id="diagnosisNameField" promptText="Впишіть новий діагноз" />
                                        <Button fx:id="btnAddDiagnosis" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddDiagnosis" text="Додати діагноз" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </content>
        </Tab>
    </tabs>
</TabPane>